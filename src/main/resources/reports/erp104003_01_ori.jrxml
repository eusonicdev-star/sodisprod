					<paragraph leftIndent="5" rightIndent="5"/>
				</textElement>
				<text><![CDATA[캐비넷,서랍장,장식장류 상품의 경우 안정적인 사용을 위해 벽고정 설치가 필수입니다.]]></text>
			</staticText>
			<staticText>
				<reportElement x="0" y="170" width="400" height="20" uuid="8a9a8c11-6b5a-4ccf-ad58-12ccec5bb592">
					<property name="com.jaspersoft.studio.unit.leftIndent" value="px"/>
					<property name="com.jaspersoft.studio.unit.rightIndent" value="px"/>
				</reportElement>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="HY신명조" size="10" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="true"/>
					<paragraph leftIndent="5" rightIndent="5"/>
				</textElement>
				<text><![CDATA[구매자는 이에 대한 충분한 안내를 받았으며, 벽고정 장치를 설치하는것에 동의합니다.]]></text>
			</staticText>
			<staticText>
				<reportElement x="0" y="190" width="440" height="20" uuid="ec9703f2-42d9-4f7f-b35b-087b181aeb9a">
					<property name="com.jaspersoft.studio.unit.leftIndent" value="px"/>
					<property name="com.jaspersoft.studio.unit.rightIndent" value="px"/>
				</reportElement>
				<box>
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="HY신명조" size="10" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="true"/>
					<paragraph leftIndent="5" rightIndent="5"/>
				</textElement>
				<text><![CDATA[※동의하지 않을경우, 벽고정 장치 미설치로 인한 인적/물적 피해를 당사는 책임지지 않습니다.]]></text>
			</staticText>
