	<script th:inline="javascript" >
	
	var myWins;
	var myGrid;



	var myGridnOCellChanged;
	
	fnObj={
			winOpen:{

			},	//END of winOpen
			comboOpen : {
				comboCmpyCd : function(){		//회사콤보목록
					myComboCmpyCd = new dhtmlXCombo("cmpyCd");
			    	comboList(myComboCmpyCd,'A','COMM','CMPY_CD','','Y','');		     
			    	myComboCmpyCd.selectOption(myComboCmpyCd.getIndexByValue(/*[[${session.cmpyCd}]]*/));
			    	myComboCmpyCd.setFontSize("12px","12px");
			    	myComboCmpyCd.attachEvent("onChange", function(value, text){
			    		myGrid.clearAll(false);
			    	});
			    	myComboCmpyCd.disable();
			    	
				},	
				comboZoneType : function(){		//권역유형 콤보
					myComboZoneType = new dhtmlXCombo("zoneType");
			    	comboList(myComboZoneType,'A','COMM','ZONE_TYPE','','Y','req');		     
			    	//myComboZoneType.selectOption(myComboZoneType.getIndexByValue(/*[[${session.cmpyCd}]]*/));
			    	myComboZoneType.selectOption(0);
			    	myComboZoneType.setFontSize("12px","12px");
			    	myComboZoneType.attachEvent("onChange", function(value, text){
			    		
			    	
			    		myGrid.clearAll(false);
			    		mycomboZoneCd.clearAll();
			    		comboList(mycomboZoneCd,'A','COMM',myComboZoneType.getSelectedValue(),'','Y','req');
			    		mycomboZoneCd.selectOption(0);
			    		
			    	});
				},	
				comboZoneCd : function(){		//권역 콤보
					mycomboZoneCd = new dhtmlXComboFromSelect("zoneCd");
			    	//comboList(mycomboZoneCd,'A','COMM','','','Y','req');		     
			    	//comboList(mycomboZoneCd,'A','COMM','1000_ZONE_CD','','Y','req');		     
			    	mycomboZoneCd.selectOption(0);
			    	mycomboZoneCd.setFontSize("12px","12px");
			    	mycomboZoneCd.attachEvent("onChange", function(value, text){
			    		myGrid.clearAll(false);
			    	});
			    	mycomboZoneCd.attachEvent("onCheck", function(value, text){

						if(!value)		//체크를 한것의 값이 없을때. 즉 제일위에 전체, 또는 선택하세요 를 체크한것이다
						{
							if(mycomboZoneCd.isChecked(0))
							{
								console.log("전체 에 체크를 했을때");	
				    			var c=0;
				    			for(var i=1;i<mycomboZoneCd.getOptionsCount();i++)
					    		{
				    				mycomboZoneCd.setChecked(i,true);
				    				c++;
					    		}
					    		mycomboZoneCd.updateOption("","",c+"개 선택","");
					    		mycomboZoneCd.selectOption(0);
					    		mycomboZoneCd.openSelect();
							}
							if(!mycomboZoneCd.isChecked(0))		//전체에 체크를 안했을때
				    		{
			    				console.log("전체 에 체크를 안했을때");	
			    				var c=0;
				    			for(var i=1;i<mycomboZoneCd.getOptionsCount();i++)
					    		{
					    				mycomboZoneCd.setChecked(i,false);
					    		}
					    		mycomboZoneCd.updateOption("","",c+"개 선택","");
					    		mycomboZoneCd.selectOption(0);
					    		mycomboZoneCd.openSelect();
				    			return;
			    			}
							
						}
						else
						{
							var cnt=0;
							
				    		for(var i=1;i<mycomboZoneCd.getOptionsCount();i++)
				    		{
				    			if(mycomboZoneCd.isChecked(i))
				    			{
				    				cnt++;
				    			}
				    		}
				    		console.log("체크한 것 cnt : " + cnt);
				    		
				    		
				    		if((mycomboZoneCd.getOptionsCount()-1) == cnt)
				    		{
				    			mycomboZoneCd.setChecked(0,true);
				    		}
				    		else
				    		{
				    			mycomboZoneCd.setChecked(0,false);
				    		}
				    		
				    		mycomboZoneCd.updateOption("","",cnt+"개 선택","");
				    		mycomboZoneCd.selectOption(0);
				    		mycomboZoneCd.openSelect();
	
							
			    			return;
						}
			    		
			    	});
				},
				
				comboSido : function(){		//시도콤보목록
					myComboSido = new dhtmlXCombo("sido");
			    	comboList(myComboSido,'A','SIDO','','','Y','req');		     
			    	myComboSido.selectOption(0);
			    	myComboSido.setFontSize("12px","12px");
			    	myComboSido.attachEvent("onChange", function(value, text){
			    		myGrid.clearAll(false);
			    		myComboSigu.clearAll();
			    		comboList(myComboSigu,'A','SIGU',myComboSido.getSelectedValue(),'','Y','req');		
			    		myComboSigu.selectOption(0);
			    	});
			    	//myComboSido.disable();
			    	
				},	
				comboSigu : function(){		//구군콤보목록
					myComboSigu = new dhtmlXCombo("sigu");
			    	//comboList(myComboSigu,'A','SIDO','','','Y','req');	
			    	myComboSigu.addOption([{value:"", text:"선택하세요"}]);
			    	myComboSigu.selectOption(0);
			    	myComboSigu.setFontSize("12px","12px");
			    	myComboSigu.attachEvent("onChange", function(value, text){
			    		myGrid.clearAll(false);
			    	});
			    	//myComboSido.disable();
			    	
				},	
			
				
				
				
			},	//END of comboOpen
			gridOpen : {
				grid : function()
				{
					myGrid.setImagePath("https://cdn.dhtmlx.com/edge/skins/terrace/imgs/");
					myGrid.setHeader("#master_checkbox,CUD,권역유형코드,권역유형명칭,권역코드,권역명칭,권역-요일배송 고유ID,요일배송적용유무,월,화,수,목,금,토,일,적용일자,메모,저장자,저장일,수정자,수정일,월원본,화원본,수원본,목원본,금원본,토원본,일원본"); 
					myGrid.setColumnIds("chk,cud,zoneType,zoneTypeNm,zoneCd,zoneNm,tblLgstWeekdlvyMId,weekdlvyYn,monYn,tueYn,wedYn,thuYn,friYn,satYn,sunYn,strtDt,memo,saveUser,saveTime,updtUser,updtTime,monYnOri,tueYnOri,wedYnOri,thuYnOri,friYnOri,satYnOri,sunYnOri");
					myGrid.setInitWidths("40,40,80,100,80,100,160,160,40,40,40,40,40,40,40,80,200,80,160,80,160,40,40,40,40,40,40,40");
					myGrid.setColAlign("center,center,center,center,center,center,center,center,center,center,center,center,center,center,center,center,left,left,left,left,left,center,center,center,center,center,center,center");
					myGrid.setColTypes("ch,ro,ro,ro,ro,ro,ro,ro,ro,ro,ro,ro,ro,ro,ro,ro,ro,ro,ro,ro,ro,ro,ro,ro,ro,ro,ro,ro");
					myGrid.setColSorting(",,,str,str,str,str,str,str,str,str,str,str,str,str,str,str,str,str,str,str,str,str,str,str,str,str,str");
					myGrid.attachHeader(",,,#text_filter,#text_filter,#text_filter,#text_filter,#text_filter,#text_filter,#text_filter,#text_filter,#text_filter,#text_filter,#text_filter,#text_filter,#text_filter,,,,,,,,,,,,");
					
					myGrid.setColumnHidden(myGrid.getColIndexById("monYnOri"),true);	//컬럼 아이디로 해당 컬럼 가리기
					myGrid.setColumnHidden(myGrid.getColIndexById("tueYnOri"),true);	//컬럼 아이디로 해당 컬럼 가리기
					myGrid.setColumnHidden(myGrid.getColIndexById("wedYnOri"),true);	//컬럼 아이디로 해당 컬럼 가리기
					myGrid.setColumnHidden(myGrid.getColIndexById("thuYnOri"),true);	//컬럼 아이디로 해당 컬럼 가리기
					myGrid.setColumnHidden(myGrid.getColIndexById("friYnOri"),true);	//컬럼 아이디로 해당 컬럼 가리기
					myGrid.setColumnHidden(myGrid.getColIndexById("satYnOri"),true);	//컬럼 아이디로 해당 컬럼 가리기
					myGrid.setColumnHidden(myGrid.getColIndexById("sunYnOri"),true);	//컬럼 아이디로 해당 컬럼 가리기
					myGrid.setStyle();
					
					myGrid.init();		//이걸써야 세팅한 그리드가 표시가 된다
					myGrid.enableSmartRendering(true);	//스마트렌더링기능 가능	//데이터를 많이 구했더라도 제일 처음 에는 화면 크기에 나올수있을만큼만 보여준다. 스크롤을 움직이면 그떄 갖고있던 데이터들을 그려주기 시작한다

					
					fnObj.gridOpen.setWidth();
																								//그래야 진짜 화면에 보이는 높이가 만들어진다
					myGrid.addRow(1,"");	//로우 추가
					//myGrid.setRowData(1,{	"commCd":""});	//처음에 빈 로우 1개를 보여준다 (좌우 스크롤 보여줄려고)
					myGrid.deleteRow(1);
					
					myGrid.attachEvent("onRowDblClicked", function(rId,cInd){
						
					
					    
					});
	

				},//grid
				setWidth : function(){
					c_width =  top.myLayout.cells("c").getWidth();
					searchDiv_height =  $("#searchDiv").height();
					searchDiv2nd_height =  $("#searchDiv2nd").height();
					xhdr_height =  $(".xhdr").height();
					
					myGrid.enableAutoWidth(true,c_width-25,100);
					myGrid.enableAutoHeight(true,window.innerHeight-searchDiv_height-searchDiv2nd_height-xhdr_height-15);	//그리드 자동높이
					
					
					$("#searchDiv").width(c_width-25);
					$("#searchDiv2nd").width(c_width-25);
					
				},	//END of setWidth
			},	//END of gridOpen
			searchOpen : {
				search : function() {	//그리드 목록 조회하기
					myGrid.clearAll(false);
					myGrid.detachEvent(myGridnOCellChanged);
				
					if(!fnObj.searchOpen.searchChkVal.chkVal("search"))
					{
						alert(chkValMsg);
						return false;
					}
					
					var srchData = new FormData();
					srchData.append("cmpyCd"		,myComboCmpyCd.getSelectedValue());
					srchData.append("zoneType"		,myComboZoneType.getSelectedValue());
					srchData.append("zoneList"		,mycomboZoneCd.getChecked());
					srchData.append("siDo"			,myComboSido.getSelectedValue());
					srchData.append("siGu"			,myComboSigu.getSelectedValue());
					srchData.append("useYn"			,"Y");
		
					for (var pair of srchData.entries()) 
					{ 
						console.log(pair[0]+ ' : ' + pair[1]);
					}

					$.ajax({
				        url: "/erp902006List",
				        processData : false,
						contentType : false,
				        data: srchData,
				        type:"POST",
				        datatype:"json",
				        //async:false,
				        success : function(res){
				        	
				     
				        	if(res){
				        		console.log(res);	

								var columns = myGrid.getColumnCount()
				        		for(var i=0;i<res.length;i++){
				        			
				        			var jsonData = {};
				        			for (var c=0; c<columns; c++){ 
				        				jsonData[myGrid.getColumnId(c)] = res[i][myGrid.getColumnId(c)];
					        		}
				        			
				        			myGrid.addRow(i+1,"");	//로우 추가	//로우는 1부터 시작해야함. 0부터 시작하면 안됨. 그래서 i 에 1을 더함
				        			myGrid.setRowData(i+1,jsonData);
				        			myGrid.cellById(i+1,myGrid.getColIndexById("chk")).setValue(	myGrid.cellById(i+1,myGrid.getColIndexById("weekdlvyYn")).getValue() == "Y" ? "1" : "0");
				        			myGrid.cellById(i+1,myGrid.getColIndexById("monYnOri")).setValue(myGrid.cellById(i+1,myGrid.getColIndexById("monYn")).getValue());
	        						myGrid.cellById(i+1,myGrid.getColIndexById("tueYnOri")).setValue(myGrid.cellById(i+1,myGrid.getColIndexById("tueYn")).getValue());
	        						myGrid.cellById(i+1,myGrid.getColIndexById("wedYnOri")).setValue(myGrid.cellById(i+1,myGrid.getColIndexById("wedYn")).getValue());
	        						myGrid.cellById(i+1,myGrid.getColIndexById("thuYnOri")).setValue(myGrid.cellById(i+1,myGrid.getColIndexById("thuYn")).getValue());
	        						myGrid.cellById(i+1,myGrid.getColIndexById("friYnOri")).setValue(myGrid.cellById(i+1,myGrid.getColIndexById("friYn")).getValue());
	        						myGrid.cellById(i+1,myGrid.getColIndexById("satYnOri")).setValue(myGrid.cellById(i+1,myGrid.getColIndexById("satYn")).getValue());
	        						myGrid.cellById(i+1,myGrid.getColIndexById("sunYnOri")).setValue(myGrid.cellById(i+1,myGrid.getColIndexById("sunYn")).getValue());
				          		}
								
								myGridnOCellChanged = myGrid.attachEvent("onCellChanged", function(rId,cInd,nValue){
			        	       		var columnId = 	myGrid.getColumnId(cInd);
			        				if(columnId == "chk"){	//컬럼 아이디가 체크면
			        					//체크하는곳이 바뀌었으면 CUD를 U 로 표시한다
			        					
			        					if(	myGrid.cellById(rId,myGrid.getColIndexById("chk")).getValue()	==	"1")	//체크를 했다
			        					{
			        						
			        						if(myGrid.cellById(rId,myGrid.getColIndexById("weekdlvyYn")).getValue() == "N")	//요일배송적용유무가 N 일때
			        						{	
			        							myGrid.cellById(rId,myGrid.getColIndexById("cud")).setValue("U");
			        					
			        							//배송적용유무 값을 가져다가 그리드에 박아넣는다	
			        							myGrid.cellById(rId,myGrid.getColIndexById("weekdlvyYn")).setValue("Y");
			        							myGrid.cellById(rId,myGrid.getColIndexById("monYn")).setValue($("#mon").is(":checked") ? "Y" : "N");
				        						myGrid.cellById(rId,myGrid.getColIndexById("tueYn")).setValue($("#tue").is(":checked") ? "Y" : "N");
				        						myGrid.cellById(rId,myGrid.getColIndexById("wedYn")).setValue($("#wed").is(":checked") ? "Y" : "N");
				        						myGrid.cellById(rId,myGrid.getColIndexById("thuYn")).setValue($("#thu").is(":checked") ? "Y" : "N");
				        						myGrid.cellById(rId,myGrid.getColIndexById("friYn")).setValue($("#fri").is(":checked") ? "Y" : "N");
				        						myGrid.cellById(rId,myGrid.getColIndexById("satYn")).setValue($("#sat").is(":checked") ? "Y" : "N");
				        						myGrid.cellById(rId,myGrid.getColIndexById("sunYn")).setValue($("#sun").is(":checked") ? "Y" : "N");
		
			        						}
			        						else if(myGrid.cellById(rId,myGrid.getColIndexById("weekdlvyYn")).getValue() == "Y")	//요일배송적용유무가 Y 일때
			        						{	
			        							myGrid.cellById(rId,myGrid.getColIndexById("cud")).setValue("U");
			        					
			        							/*
			        							//배송적용유무 값을 가져다가 그리드에 박아넣는다	
			        							myGrid.cellById(rId,myGrid.getColIndexById("monYn")).setValue($("#mon").is(":checked") ? "Y" : "N");
				        						myGrid.cellById(rId,myGrid.getColIndexById("tueYn")).setValue($("#tue").is(":checked") ? "Y" : "N");
				        						myGrid.cellById(rId,myGrid.getColIndexById("wedYn")).setValue($("#wed").is(":checked") ? "Y" : "N");
				        						myGrid.cellById(rId,myGrid.getColIndexById("thuYn")).setValue($("#thu").is(":checked") ? "Y" : "N");
				        						myGrid.cellById(rId,myGrid.getColIndexById("friYn")).setValue($("#fri").is(":checked") ? "Y" : "N");
				        						myGrid.cellById(rId,myGrid.getColIndexById("satYn")).setValue($("#sat").is(":checked") ? "Y" : "N");
				        						myGrid.cellById(rId,myGrid.getColIndexById("sunYn")).setValue($("#sun").is(":checked") ? "Y" : "N");
		*/
												myGrid.cellById(rId,myGrid.getColIndexById("weekdlvyYn")).setValue("N");
				        						myGrid.cellById(rId,myGrid.getColIndexById("monYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("monYnOri")).getValue());
				        						myGrid.cellById(rId,myGrid.getColIndexById("tueYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("tueYnOri")).getValue());
				        						myGrid.cellById(rId,myGrid.getColIndexById("wedYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("wedYnOri")).getValue());
				        						myGrid.cellById(rId,myGrid.getColIndexById("thuYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("thuYnOri")).getValue());
				        						myGrid.cellById(rId,myGrid.getColIndexById("friYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("friYnOri")).getValue());
				        						myGrid.cellById(rId,myGrid.getColIndexById("satYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("satYnOri")).getValue());
				        						myGrid.cellById(rId,myGrid.getColIndexById("sunYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("sunYnOri")).getValue());
				        						
				        						
			        						}
			        						
			        						
			        					}
			        					else		//체크를 해제했을때
			        					{
			        						
			        						
			        						
			        						if(myGrid.cellById(rId,myGrid.getColIndexById("weekdlvyYn")).getValue() == "N")	//요일배송적용유무가 N 일때
			        						{	
			        							myGrid.cellById(rId,myGrid.getColIndexById("cud")).setValue("");
			        						
			        							//오리지날을 가져다가 그리드에 박아넣는다	
			        							/*
			        							myGrid.cellById(rId,myGrid.getColIndexById("monYn")).setValue("");
				        						myGrid.cellById(rId,myGrid.getColIndexById("tueYn")).setValue("");
				        						myGrid.cellById(rId,myGrid.getColIndexById("wedYn")).setValue("");
				        						myGrid.cellById(rId,myGrid.getColIndexById("thuYn")).setValue("");
				        						myGrid.cellById(rId,myGrid.getColIndexById("friYn")).setValue("");
				        						myGrid.cellById(rId,myGrid.getColIndexById("satYn")).setValue("");
				        						myGrid.cellById(rId,myGrid.getColIndexById("sunYn")).setValue("");
				        						*/
				        						myGrid.cellById(rId,myGrid.getColIndexById("weekdlvyYn")).setValue("Y");
				        						myGrid.cellById(rId,myGrid.getColIndexById("monYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("monYnOri")).getValue());
				        						myGrid.cellById(rId,myGrid.getColIndexById("tueYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("tueYnOri")).getValue());
				        						myGrid.cellById(rId,myGrid.getColIndexById("wedYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("wedYnOri")).getValue());
				        						myGrid.cellById(rId,myGrid.getColIndexById("thuYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("thuYnOri")).getValue());
				        						myGrid.cellById(rId,myGrid.getColIndexById("friYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("friYnOri")).getValue());
				        						myGrid.cellById(rId,myGrid.getColIndexById("satYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("satYnOri")).getValue());
				        						myGrid.cellById(rId,myGrid.getColIndexById("sunYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("sunYnOri")).getValue());
		
			        						}
			        						else if(myGrid.cellById(rId,myGrid.getColIndexById("weekdlvyYn")).getValue() == "Y")	//요일배송적용유무가 Y 일때
			        						{	
			        							myGrid.cellById(rId,myGrid.getColIndexById("cud")).setValue("U");
			        						
			        							//공백을 가져다가 그리드에 박아넣는다	
			        							myGrid.cellById(rId,myGrid.getColIndexById("weekdlvyYn")).setValue("N");
			        							myGrid.cellById(rId,myGrid.getColIndexById("monYn")).setValue("");
				        						myGrid.cellById(rId,myGrid.getColIndexById("tueYn")).setValue("");
				        						myGrid.cellById(rId,myGrid.getColIndexById("wedYn")).setValue("");
				        						myGrid.cellById(rId,myGrid.getColIndexById("thuYn")).setValue("");
				        						myGrid.cellById(rId,myGrid.getColIndexById("friYn")).setValue("");
				        						myGrid.cellById(rId,myGrid.getColIndexById("satYn")).setValue("");
				        						myGrid.cellById(rId,myGrid.getColIndexById("sunYn")).setValue("");
				        						
				        						/*
				        						myGrid.cellById(rId,myGrid.getColIndexById("monYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("monYnOri")).getValue());
				        						myGrid.cellById(rId,myGrid.getColIndexById("tueYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("tueYnOri")).getValue());
				        						myGrid.cellById(rId,myGrid.getColIndexById("wedYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("wedYnOri")).getValue());
				        						myGrid.cellById(rId,myGrid.getColIndexById("thuYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("thuYnOri")).getValue());
				        						myGrid.cellById(rId,myGrid.getColIndexById("friYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("friYnOri")).getValue());
				        						myGrid.cellById(rId,myGrid.getColIndexById("satYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("satYnOri")).getValue());
				        						myGrid.cellById(rId,myGrid.getColIndexById("sunYn")).setValue(myGrid.cellById(rId,myGrid.getColIndexById("sunYnOri")).getValue());
												*/
			        						}
			        					}
			        				}
			        			});
				        	}
				        	else{
				       			alert("권역별-요일배송관리 조회 수행 결과 없음");
				        	}
				        },
					});
		
				},	//END of search : function() {
				
				weekBatchSave : function() {	//일괄저장 버튼
					
				if(!confirm("저장하시겠습니까?"))
				{
					alert("취소하였습니다");
					return;
				}
		
					var weekBatchSaveData=[];
					var myGridData = get_cud_json(myGrid);
					for(var i=0;i<myGridData.length;i++)
					{
						myGridData[i].saveUser = /*[[${session.tblUserMId}]]*/;

		
						if(myGridData[i].tblLgstWeekdlvyMId)	//고유아이디 값이 있다
						{
							myGridData[i].saveGubn = "UPDT";
						}
						else
						{
							myGridData[i].saveGubn = "INS";
						}
						
						weekBatchSaveData.push(myGridData[i])
					}
					console.log(JSON.stringify(weekBatchSaveData));
				
					$.ajax({
				        url: "/erp902006Save",
				        processData : false,
						//contentType : false,
						contentType : "application/json",	//데이터를 어레이 json으로 보낼때에는 contentType : "application/json" 를 붙인다
				        data: JSON.stringify(weekBatchSaveData),
				        type:"POST",
				        datatype:"json",
				        //async:false,
				        success : function(res){
				        	if(res){
				        		console.log(res);
				        		var rtnYnCnt=0;
				        		for(var i=0;i<res.length;i++)
				        		{
				        			if(res[i].rtnYn == "Y")
				        			{
				        				rtnYnCnt++;
				        			}
				        		}
				        		alert(res.length +" 중 " + rtnYnCnt+" 건 성공");
				        		fnObj.searchOpen.search();
				        	}
				        	else{
				       			alert("일괄저장 수행 결과 없음");
				        	}
				        },
					});
				},	//END of weekBatchSave : function() {

			searchChkVal : {
				chkVal : function(chkGubn){
					chkValMsg="";	//메세지 초기화
					var rtnVal = true;
					
					if(chkGubn == "search")
					{
						if(!myComboCmpyCd.getSelectedValue()){
							chkValMsg = chkValMsg + "회사코드가 없습니다\n";
							rtnVal = false;
						}
						
						if(!myComboZoneType.getSelectedValue()){
							chkValMsg = chkValMsg + "권역유형을 선택하세요\n";
							rtnVal = false;
						}
		
					
						
						var c=0;
		    			for(var i=1;i<mycomboZoneCd.getOptionsCount();i++)
			    		{
		    				if(mycomboZoneCd.isChecked(i))
		    				{
		    					c++;
		    				}
			    		}
		    			//console.log("c : " + c)
		    			if(c == 0){
							chkValMsg = chkValMsg + "권역을 체크하세요\n";
							rtnVal = false;
						}
		    			
		    			
		    			/*
						
						if(!myComboSido.getSelectedValue()){
							chkValMsg = chkValMsg + "시/도를 선택하세요\n";
							rtnVal = false;
						} 
						
						if(!myComboSigu.getSelectedValue()){
							chkValMsg = chkValMsg + "구/군을 선택하세요\n";
							rtnVal = false;
						}
						*/
						
					}
					
					return rtnVal;
				},	//END of chkVal : function(){
			},	//END of searchChkVal
		},	//END of searchOpen
	}


	//엑셀 헨들러
	var excelHandler = {
	    getExcelFileName : function(){
	        return '배송달력관리.xlsx';		//엑셀파일명
	    },
	    getSheetName : function(){
	        return '배송달력관리';		//시트명
	    },
	    getExcelData : function(){
	        return	get_json_for_excel(myGrid);		//그리드를 엑셀다운로드dyd json 으로 변경
	    },
	    getWorksheet : function(){
	        return XLSX.utils.json_to_sheet(this.getExcelData());
	    }
	}
		
			
$(document).ready(function() {
	console.log(pageUrl());

	myWins = new dhtmlXWindows();
	
	myGrid = new dhtmlXGridObject('grid');	//그리드

	
	
	
	fnObj.comboOpen.comboCmpyCd();	//회사콤보 바인드
	fnObj.comboOpen.comboZoneType();	//권역유형콤보 바인드
	fnObj.comboOpen.comboZoneCd();	//권역콤보 바인드
	fnObj.comboOpen.comboSido();	//시도콤보 바인드
	fnObj.comboOpen.comboSigu();	//구군콤보 바인드


	
	
	fnObj.gridOpen.grid()

	
	
	window.onresize = function(event) {		//윈도우의 사이즈가 변경했을떄
		fnObj.gridOpen.setWidth();
		fnObj.gridOpen.setWidth();
	};

});


</script>
</head>
<!-- top , left, bottom , right,  -->
<body>
	<div id="mainDiv"  style="padding:10px 10px 0 10px;" >
		<div id="searchDiv" style="width:100%;font-size:12px;padding-bottom:5px;">
			<div id="btnDiv1" style="width:100%;">
				<span class="cell" style="float:right;">
					<span class="item-data" style="padding: 0 0 0 20px;"><input id="btnSearch" type="button" onclick="fnObj.searchOpen.search()" value="조회"></span>
					<span class="item-data" style="padding: 0 0 0 20px;"><input id="btnExcelDown" type="button" onclick="exportExcel();" value="엑셀다운로드"></span>
				</span>
			</div>
			<div id="searchDiv1" style="width:100%;">
				<span class="cell" style="width:220px;">
					<span class="item-head" style="width:80px;">회사</span>
					<span class="item-data" style="width:140px;"><div id="cmpyCd" ></div></span>
				</span>
				<span class="cell" style="width:220px;">
					<span class="item-head" style="width:80px;">권역유형</span>
					<span class="item-data" style="width:140px;"><div id="zoneType" ></div></span>
				</span>
				
				<span class="cell" style="width:220px;">
					<span class="item-head" style="width:80px;">권역</span>
					<span class="item-data" style="width:140px;"><div opt_type="checkbox" id="zoneCd" ></div></span>

				</span>
				<span class="cell" style="width:220px;">
					<span class="item-head" style="width:80px;">시/도</span>
					<span class="item-data" style="width:140px;"><div id="sido"></div></span>
				</span>
				<span class="cell" style="width:220px;">
					<span class="item-head" style="width:80px;">구/군</span>
					<span class="item-data" style="width:140px;"><div id="sigu"></div></span>
				</span>
			</div>
			
			
		</div>
		
		<div id="searchDiv2nd" style="width:100%;font-size:12px;padding-bottom:5px;background-color: papayawhip;">
			<div id="btnDiv2nd1" style="width:100%;">
				<span class="cell" style="float:right;">
					<span class="item-data" style="padding: 0 0 0 20px;"><input id="btnweekBatch" type="button" onclick="fnObj.searchOpen.weekBatchSave()" value="저장"></span>
				</span>
			</div>
			<div id="searchDiv2nd1" style="width:100%;">
			
				<span class="cell" style="align-items: center;">
					<span class="item-head" style="width:80px;"></span>
					<span class="item-data">
						<input type="checkBox" id="mon" name="week" value="MON">월</input>&nbsp;&nbsp;
						<input type="checkBox" id="tue" name="week" value="TUE">화</input>&nbsp;&nbsp;
						<input type="checkBox" id="wed" name="week" value="WED">수</input>&nbsp;&nbsp;
						<input type="checkBox" id="thu" name="week" value="THU">목</input>&nbsp;&nbsp;
						<input type="checkBox" id="fri" name="week" value="FRI">금</input>&nbsp;&nbsp;
						<input type="checkBox" id="sat" name="week" value="SAT"><font color="blue">토</font></input>&nbsp;&nbsp; 
						<input type="checkBox" id="sun" name="week" value="SUN"><font color="red">일</font></input>  
					</span>
				</span>
			</div>
		</div>
		
		
		<div id="gridDiv"  style="width:100%;font-size:12px;padding-bottom:5px;">
			<div id="grid" style="width:25%;height:100%;"></div>
		</div>
	</div>
</body>
</html>
